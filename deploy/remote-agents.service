[Unit]
Description=remote-agents Backend
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/ubuntu/remote-agents/backend
ExecStart=/home/ubuntu/remote-agents/backend/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8080
Environment=PI_WORKSPACE=/srv/workspace
Environment=PI_PROVIDER=opencode-go
Environment=PI_MODEL=mimo-v2.5-pro
Environment=PATH=/home/ubuntu/.local/bin:/usr/local/bin:/usr/bin:/bin:/usr/local/lib/nodejs/bin
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
